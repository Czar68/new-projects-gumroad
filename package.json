  "description": "Props EV Blueprint + E-commerce Profit sheet pipeline; Gumroad loop.",
  "private": true,
  "scripts": {
    "dry": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tests/final_smoke_test.ps1",
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tests/final_smoke_test.ps1",
    "smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File ./tests/final_smoke_test.ps1",
    "loop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/gumroad_loop.ps1",
    "loop:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/gumroad_loop.ps1 -AuditOnly",
    "loop:next": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/gumroad_loop.ps1 -GenerateNextOnly",
    "factory:generate": "node ./scripts/factory_generate.js",
    "factory:validate": "node ./tests/validate_factory_slice.js",
    "listing:compile": "node ./scripts/compile_listing_package.js",
    "listing:validate": "node ./tests/validate_listing_compiler_slice.js",
    "listing:inventory": "node ./scripts/list_listing_packages.js",
    "listing:inventory:validate": "node ./tests/validate_listing_inventory_slice.js",
    "listing:handoff": "node ./scripts/select_handoff_run.js",
    "listing:handoff:validate": "node ./tests/validate_handoff_selector_slice.js",
    "listing:handoff:bundle": "node ./scripts/build_handoff_bundle.js",
    "listing:handoff:bundle:validate": "node ./tests/validate_handoff_bundle_slice.js",
    "export:gumroad:selected-pricing-decision": "node ./scripts/export-selected-pricing-decision.js",
    "verify:gumroad:selected-pricing-decision": "node ./scripts/verify-selected-pricing-decision.js"
